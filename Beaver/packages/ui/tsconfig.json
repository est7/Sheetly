{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["react", "react-dom"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@beaver/ui/*": ["./*"]
    }
  },
  "include": ["components/**/*.tsx", "lib/**/*.ts", "index.ts"]
}
