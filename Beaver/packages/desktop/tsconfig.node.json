{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "electron-vite/node"],
    "lib": ["ES2023", "DOM"],
    "paths": {
      "@beaver/core": ["../core/src/index.ts"],
