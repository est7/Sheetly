{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["react", "react-dom"],
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "paths": {
      "@": ["./src/renderer/src"],
      "@/*": ["./src/renderer/src/*"],
      "@beaver/ui/*": ["../ui/*"]
    }
  },
  "include": ["src/renderer/src/**/*.ts", "src/renderer/src/**/*.tsx", "src/preload/index.d.ts"]
}
