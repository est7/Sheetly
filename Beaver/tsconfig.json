{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals"],
    "paths": {
      "@beaver/core": ["./packages/core/src/index.ts"],
      "@beaver/core/*": ["./packages/core/src/*"],
      "@beaver/daemon": ["./packages/daemon/src/index.ts"],
      "@beaver/daemon/*": ["./packages/daemon/src/*"],
      "@beaver/client": ["./packages/client/src/index.ts"],
      "@beaver/client/*": ["./packages/client/src/*"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "apps/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "packages/daemon/src/repository/**",
    "packages/daemon/src/orchestrator/**",
    "packages/daemon/tests/**"
  ]
}
